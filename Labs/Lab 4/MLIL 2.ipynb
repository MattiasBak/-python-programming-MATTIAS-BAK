# %% [markdown]
# # Inläning av Torchcam och analys

# %%
from torchvision.io import decode_image
from torchvision.models import get_model, get_model_weights
from torchcam.methods import LayerCAM
import matplotlib.pyplot as plt
from torchvision.transforms.v2.functional import to_pil_image
from torchcam.utils import overlay_mask
import json
import torch
import os

# %% [markdown]
# Här hämtar vi som vanligt in de bibliotek som vi behöver för att fullfölja uppgiften

# %%
weights = get_model_weights ('resnet18').DEFAULT
model = get_model('resnet18', weights=weights).eval()

preprocess  = weights.transforms()
img = decode_image ("C:/Users/matti/Downloads/Atlas_moth.webp")
plt.imshow(to_pil_image(img))
plt.axis('off')

# %% [markdown]
# Vi kommer at använda oss av denna bilden på en Atlasapinnare (Attacus atlas) i vårat test för att kolla pålitligheten av programet. Vi kan se att den har ett väldigt distinkt utseende vilket kan vara oss till gagn.

# %%
input_tensor= preprocess (img)

with LayerCAM(model, target_layer='layer4') as cam_extractor:
    out = model (input_tensor.unsqueeze(0))
    activation_map = cam_extractor (out.squeeze(0).argmax().item(), out)


# %%
plt.imshow(activation_map[0].squeeze(0).numpy())
plt.axis('off')
plt.tight_layout()
plt.show()
img = decode_image ("C:/Users/matti/Downloads/Atlas_moth.webp")
plt.imshow(to_pil_image(img))
plt.axis('off')


# %% [markdown]
# Vi kan se att programmet fokuserar på två punkter, en på nästan vardera del av bilden. Men vad är det som detta ger oss? Vi kan se hur dessa punkter blir de som anses vara mest distinkta eller talande för vad som tros kunna användas för att lista ut vad det kan vara. Detta är bara första lagret som vi använder så den kan hitta nya eller skifta fokus helt (även om detta inte är troligt).

# %%

result = overlay_mask(to_pil_image(img), to_pil_image(activation_map[0].squeeze(0), mode='F'),alpha=0.5)
plt.imshow(result)
plt.axis('off')
plt.tight_layout
plt.show()


# %% [markdown]
# Här oven ser vi nu resultatet av alla fyra lager. Vi kan klart se att den har fortsatt att fokusera på bägge vingarna på Atlasspinnaren och därgenom kan vi säga att det är dessa delar som den finner ger bäst resultat.

# %%
def pred_top5 (output_tensor: torch.Tensor, class_index_path: str) -> dict:
    with open (class_index_path, 'r') as f:
        class_index = json.load(f)
    prob = torch.softmax(output_tensor.squeeze(),dim=0)
    top5_prob, top5_ind = torch.topk(prob, 5)


    for i in range (5):
        ind = str(top5_ind[i].item())
        probability = top5_prob[i].item() * 100
        class_name = class_index[ind][1]
        print(f"{i+1}: {class_name} ({probability:.2f}%)")
pred_top5 (out.detach(),"C:/Users/matti/Downloads/imagenet_class_index.json")
        

# %%
Atlas_kam = ["C:/Users/matti/Downloads/Atlas_moth.webp", "C:/Users/matti/Downloads/Afrikansk_Kameleont.jpg"]
for pics in Atlas_kam:
    Atlas_kam=decode_image(pics)
    plt.imshow(to_pil_image(Atlas_kam))
    plt.axis('off')
    plt.show()



# %% [markdown]
# Men vad var det som låter den ta dessa slutsatser. Jag har mina misstankar i detta och att det har med formen på kameleontens svans och huvud som låter den tro att Atlasspinnaren är densamma.

# %%
pic=[]
Both = [('Atlasspinnare', "C:/Users/matti/Downloads/Atlas_moth.webp"),
        ('Afrikansk Kameleont',"C:/Users/matti/Downloads/Afrikansk_Kameleont.jpg"),
 ]
for Name, photo in Both:
    photo=decode_image(photo)
    pic.append(photo)

    layers = ['layer1', 'layer2', 'layer3', 'layer4']
    with LayerCAM (model, target_layer=layers) as cam_extractor:
        out= model(preprocess(photo).unsqueeze(0))
        activation_map = cam_extractor(out.squeeze(0).argmax(0).item(), out)

    fig, axes= plt.subplots(1, len(layers),figsize=(30,10), constrained_layout= True)
    fig.suptitle(Name, fontsize =40)

    for i, (act_map, layer_name) in enumerate(zip(activation_map, layers)):
        result = overlay_mask (to_pil_image(photo), to_pil_image (act_map.squeeze(0),mode='F'), alpha=0.5)

        axes[i].imshow(result)
        axes[i].set_title((layer_name), fontsize= 30)
        axes[i].axis('off')

# %% [markdown]
# Den skriver att det skall vara en Afrikansk kamiljont, men med bara en 12% säkerhet. Vad innebär då detta för oss. Vi kan med detta svar utgå ifrån att Atlasspinnare inte finns i filen. Om vi tittar vidare på dessa två bilder så kan vi se i lite mer detalj hur arbetet går till. I lager ett så kan vi se hur den fokuserar på de pixlar som är vid kanter, enklare former men även färgövergångar. Detta ger oss konturer och skapar en silluett som är en grov estimation av vad som eftersöks. Vi kan även se en hur den börjar hitta delar av intresse (de röda markeringarna). Medan lager 2 och 3 börjar titta på texturerna i bilderna och leta upp saker som är av lite enklare struktur tex lemar. Den använder dessa för att börja skaffa sig en förståelse av vad bilden kan föreställa. Det sista lagret, det fjärde, går in på hur de olika delarna sitter samman och försöker skapa en helhet. I varje lager så jänförs strukturer och bilder som inte passar sållas bort stegvis. Vi ser att den fokuserar väldigt tunkt på kameleontens huvud och svans. Dess huvud är en klar del av ödlan där större delen av dess distinkta former finns. Men när vi tittar på dess fokus på atlasspinnaren så får den ifrån huvudet och fokuserar på dess vingar. Detta är något som jag finner förvånande då vingarna på spinnaren inte är av liknande former som kameleontens huvud. Vad är det som leder den till att ta detta beslut? om vi ser till dess högra vinge så kan vi misstänka att vingspetsen blir misstolkat till en ödlas trubbiga nos. Detta är en möjlighet, men det är svårt att säga att det är så det faktiskt är.

# %%
model.eval()
for Name, x in Both:
    Image_fokus = decode_image (x)
    sack = preprocess(Image_fokus).unsqueeze(0)
    what_both = model(sack).squeeze(0).softmax(0)
    print(f'\n{Name}:')
    text= pred_top5 (what_both.detach(),"C:/Users/matti/Downloads/imagenet_class_index.json")



# %% [markdown]
# Vår sökning ger oss altså en 12% sanolikhet att det är en kameleont vi ser när vi ber den att analysera bilden på spinnaren. Detta låter inte som ett väldigt säkert val, faktum är at Cicada ligger där på samma 12%. Men om vi tittar till hur säker den är när det faktiskt är en kameleont så visar det sig att det bara går upp till 27%. Detta är inte väldigt övertygande och kan i stor utsträckning anses vara en gissning även om det är en korrekt gissning. Vi kan då avgöra att den har svårt att se skillnad på Atlasspinnarens vinge och kameleontens huvud kan blanda ihop dessa. Eller så finns inte Atlasspinnaren i våran data och kameleont var det som var närmast i likhet.

